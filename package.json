{
  "name": "mosquito-tycoon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "bot": "node bot.js",
    "tunnel": "cloudflared tunnel --config .cloudflared/config.yml run",
    "start": "concurrently -k -n vite,server,bot,tunnel -c cyan,green,yellow,magenta \"npm:dev\" \"npm:server\" \"npm:bot\" \"npm:tunnel\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^6.0.7"
  }
}
